{
    "manifest_version": 2,
    "name": "Sender auto update",
    "description": "Extension updates from field to original receipient when replying to email.",
    "version": "1.0",
    "author": "MarioZG",
    "homepage_url": "https://github.com/MarioZG/thunderbird-sendfrom",
    "browser_specific_settings": {
        "gecko": {
            "strict_min_version": "128.0"
        }
    },
    "permissions": [
        "compose","messagesRead"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "icons": {
        "64": "images/icon.svg",
        "32": "images/icon.svg",
        "16": "images/icon.svg"
    }
}